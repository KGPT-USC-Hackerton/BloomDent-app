# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# iOS 최소 버전(React Native 템플릿에서 쓰는 헬퍼)
def min_ios_version_supported
  '15.1'
end

# ✅ RN 템플릿 스타일대로 helper 사용
platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'BloomDent' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # ✅ TFLite Swift 인터프리터 사용
  #  (예전에 TensorFlowLiteC 썼다면 그 줄은 삭제!)
  pod 'TensorFlowLiteSwift'


  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # fmt 11.0.2 + Xcode 26 / clang 21 에서 consteval 컴파일 에러 회피
    # ("Call to consteval function basic_format_string is not a constant expression")
    # base.h 가 FMT_USE_CONSTEVAL 를 가드 없이 무조건 재정의하므로 -D 로는 못 막는다.
    # 헤더의 consteval 감지 결과를 강제로 0(off)으로 패치한다.
    fmt_base_h = File.join(installer.sandbox.root, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base_h)
      contents = File.read(fmt_base_h)
      patched = contents.gsub(/#  define FMT_USE_CONSTEVAL 1/, '#  define FMT_USE_CONSTEVAL 0')
      if patched != contents
        File.chmod(0644, fmt_base_h)
        File.write(fmt_base_h, patched)
        Pod::UI.puts "[fmt patch] FMT_USE_CONSTEVAL forced to 0 in base.h".green
      end
    end
  end
end
